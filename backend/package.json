{
  "name": "pulse-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "seed": "tsx --env-file=.env src/scripts/seed.ts",
    "build": "tsc",
    "start": "node --env-file=.env dist/index.js",
    "db:generate": "dotenv -e .env -- drizzle-kit generate",
    "db:migrate": "dotenv -e .env -- drizzle-kit migrate",
    "db:push": "dotenv -e .env -- drizzle-kit push",
    "db:studio": "dotenv -e .env -- drizzle-kit studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@hono/node-server": "^1.12.0",
    "@hono/zod-validator": "^0.7.6",
    "@neondatabase/serverless": "^0.9.4",
    "@upstash/redis": "^1.31.0",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.31.2",
    "hono": "^4.4.7",
    "jose": "^6.2.1",
    "openai": "^4.52.2",
    "pino": "^9.3.1",
    "pino-pretty": "^11.2.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.10",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.22.7",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
